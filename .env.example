# Copie este arquivo para ".env" e preencha com as credenciais da SUA conta AWS.
# NUNCA commite o arquivo ".env" (ele já está no .gitignore).

# Credenciais principais (EC2, ELB, S3, ACM)
# A região NÃO fica aqui — isso é preferência, não segredo, e mora em config/settings.php.
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
# Só preencha AWS_SESSION_TOKEN se a credencial acima for TEMPORÁRIA (STS/AssumeRole/SSO).
# Uma Access Key comum de usuário IAM (criada em IAM > Users > Security credentials) não usa isso — deixe vazio.
AWS_SESSION_TOKEN=

# Credenciais do Route 53 (pode ser a mesma conta acima ou uma conta separada)
AWS_ROUTE53_ACCESS_KEY_ID=YOUR_ROUTE53_ACCESS_KEY_ID
AWS_ROUTE53_SECRET_ACCESS_KEY=YOUR_ROUTE53_SECRET_ACCESS_KEY

# Token de API do Cloudflare (permissão "Edit DNS records" na zona)
CLOUDFLARE_API_TOKEN=YOUR_CLOUDFLARE_API_TOKEN

# Opcional. Só preencha se chamadas HTTPS do PHP falharem com "unable to get local
# issuer certificate" — geralmente causado por antivírus/proxy que inspeciona TLS
# (ex.: Avast Web Shield). Aponte para um cacert.pem que inclua a CA desse software.
SSL_CA_BUNDLE_PATH=
