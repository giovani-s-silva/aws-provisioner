# Copy this file to ".env" and fill it with YOUR AWS account's credentials.
# NEVER commit the ".env" file (it's already in .gitignore).

# Main credentials (EC2, ELB, ACM)
# The region does NOT go here — that's a preference, not a secret, and lives in config/settings.php.
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
# Only fill in AWS_SESSION_TOKEN if the credential above is TEMPORARY (STS/AssumeRole/SSO).
# A regular IAM user Access Key (created under IAM > Users > Security credentials) doesn't use this — leave it empty.
AWS_SESSION_TOKEN=

# Route 53 credentials (can be the same account above, or a separate one)
AWS_ROUTE53_ACCESS_KEY_ID=YOUR_ROUTE53_ACCESS_KEY_ID
AWS_ROUTE53_SECRET_ACCESS_KEY=YOUR_ROUTE53_SECRET_ACCESS_KEY

# Optional. Only fill this in if PHP's HTTPS calls fail with "unable to get local
# issuer certificate" — usually caused by an antivirus/proxy that inspects TLS
# (e.g. Avast Web Shield). Point it at a cacert.pem that includes that software's CA.
SSL_CA_BUNDLE_PATH=
